{
  "name": "value-stream-1-default",
  "description": "Default bundle for value stream 1: Confluence publishing, architecture doc generation, Jira ticketing from code, and Atlassian MCP.",
  "version": "1.0.0",
  "author": {
    "name": "danforceDJ"
  },
  "license": "MIT",
  "keywords": [
    "atlassian",
    "confluence",
    "jira",
    "architecture",
    "bundle"
  ],
  "category": "bundles",
  "tags": [
    "atlassian",
    "bundle",
    "workflow"
  ],
  "mcpServers": {
    "atlassian": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote@latest",
        "https://mcp.atlassian.com/v1/sse"
      ]
    },
    "AWS Documentation MCP Server": {
      "command": "uvx",
      "args": [
        "awslabs.aws-documentation-mcp-server@latest"
      ],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_DOCUMENTATION_PARTITION": "aws"
      }
    }
  }
}
