.idea/

# ──────────────────────────────────────────────
# Generated files — what IS and IS NOT committed
# ──────────────────────────────────────────────
# NOT committed (ignored here):
#   docs/              — static site + zips, rebuilt by CI deploy workflow
#
# Intentionally committed (do NOT add these to .gitignore):
#   system/artifacts/catalog.json                           — search index for web + CI
#   .github/plugin/marketplace.json                         — Copilot CLI marketplace manifest
#   system/artifacts/claude.marketplace.json                — Claude CLI marketplace manifest
#   .vscode/mcp.json                                        — shared team MCP workspace config
#   .github/prompts/*.prompt.md                             — Copilot IDE prompt files
#   .github/instructions/catalog-agent.instructions.md      — Copilot agent instructions
#   catalog/plugins/*/.copilot-plugin/                      — Copilot CLI compatibility shims
#   catalog/plugins/*/.claude-plugin/                       — Claude CLI compatibility shims
#   catalog/plugins/*/claude-plugin.json                    — Claude CLI manifests
#
# Regenerate all of the above with:
#   uv run --script system/scripts/generate_catalog.py
#   uv run --script system/scripts/generate_marketplace.py
#   uv run --script system/scripts/generate_claude_marketplace.py
#   uv run --script system/scripts/generate_vscode_artifacts.py

# Generated by Pages deploy pipeline (served from artifact, not committed)
# The entire docs/ directory is build output — never commit it.
docs/

# Python / uv
__pycache__/
.pytest_cache/
.venv/
*.pyc
uv.lock

# macOS
.DS_Store

# Secrets / environment files — never commit credentials or tokens
.env
.env.*
*.pem
*.key

