{
  "name": "ai-catalog",
  "owner": {
    "name": "danforceDJ",
    "email": "danforceDJ@users.noreply.github.com"
  },
  "metadata": {
    "description": "Company-wide AI configuration marketplace: MCP servers, skills, agent profiles, prompts.",
    "version": "1.0.0"
  },
  "plugins": [
    {
      "name": "atlassian-mcp",
      "source": "plugins/atlassian-mcp",
      "description": "Atlassian Rovo MCP Server via OAuth 2.1 (SSO). No API tokens required in this repository.",
      "version": "1.0.0",
      "author": {
        "name": "danforceDJ"
      },
      "license": "MIT",
      "keywords": [
        "atlassian",
        "jira",
        "confluence",
        "rovo",
        "mcp"
      ],
      "category": "integrations",
      "tags": [
        "atlassian",
        "mcp"
      ],
      "mcpServers": {
        "atlassian": {
          "type": "stdio",
          "command": "npx",
          "args": [
            "-y",
            "mcp-remote@latest",
            "https://mcp.atlassian.com/v1/sse"
          ]
        }
      }
    },
    {
      "name": "default-agent",
      "source": "plugins/default-agent",
      "description": "Company-wide default agent profile enforcing git workflow, security, and conventional commit conventions.",
      "version": "1.0.0",
      "author": {
        "name": "danforceDJ"
      },
      "license": "MIT",
      "keywords": [
        "agent",
        "conventions",
        "git",
        "security"
      ],
      "category": "governance",
      "tags": [
        "default"
      ],
      "agents": [
        "default"
      ]
    },
    {
      "name": "jira-ticket-from-code",
      "source": "plugins/jira-ticket-from-code",
      "description": "Create Jira tickets from TODO/FIXME/BUG code comments by extracting intent and nearby implementation context.",
      "version": "1.0.0",
      "author": {
        "name": "danforceDJ"
      },
      "license": "MIT",
      "keywords": [
        "jira",
        "tickets",
        "code-comments",
        "todo"
      ],
      "category": "productivity",
      "tags": [
        "jira",
        "atlassian"
      ],
      "skills": [
        "jira-ticket-from-code"
      ]
    },
    {
      "name": "pr-description-prompt",
      "source": "plugins/pr-description-prompt",
      "description": "Slash command that emits a standard PR description with summary, test plan, and checklist.",
      "version": "1.0.0",
      "author": {
        "name": "danforceDJ"
      },
      "license": "MIT",
      "keywords": [
        "pr",
        "pull-request",
        "prompt",
        "template"
      ],
      "category": "productivity",
      "tags": [
        "github",
        "prompt"
      ],
      "commands": [
        "pr-description"
      ]
    },
    {
      "name": "value-stream-1-default",
      "source": "plugins/value-stream-1-default",
      "description": "Default bundle for value stream 1: Confluence publishing, architecture doc generation, Jira ticketing from code, and Atlassian MCP.",
      "version": "1.0.0",
      "author": {
        "name": "danforceDJ"
      },
      "license": "MIT",
      "keywords": [
        "atlassian",
        "confluence",
        "jira",
        "architecture",
        "bundle"
      ],
      "category": "bundles",
      "tags": [
        "atlassian",
        "bundle",
        "workflow"
      ],
      "skills": [
        "publish-to-confluence",
        "generate-architecture-doc",
        "jira-ticket-from-code"
      ],
      "mcpServers": {
        "atlassian": {
          "type": "stdio",
          "command": "npx",
          "args": [
            "-y",
            "mcp-remote@latest",
            "https://mcp.atlassian.com/v1/sse"
          ]
        }
      }
    }
  ]
}
